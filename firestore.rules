rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn(); // Relaxed for smoother initial onboarding
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email']) &&
             data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100;
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['name', 'createdBy', 'createdAt', 'memberIds']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time &&
             data.memberIds is list && data.memberIds.size() > 0 && data.memberIds.size() <= 50;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['groupId', 'description', 'amount', 'paidBy', 'splitType', 'splits', 'createdAt']) &&
             data.groupId is string && isValidId(data.groupId) &&
             data.description is string && data.description.size() <= 200 &&
             data.amount is number && data.amount > 0 &&
             data.splitType in ['equal', 'exact', 'percent', 'shares'] &&
             data.splits is map &&
             data.createdAt == request.time;
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // No blanket listing of users
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive']);
    }

    match /groups/{groupId} {
      function isMember() {
        return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }

      allow get: if isMember();
      allow list: if isSignedIn() && resource.data.memberIds.hasAny([request.auth.uid]);
      
      allow create: if isEmailVerified() && isValidGroup(incoming()) && incoming().memberIds.hasAny([request.auth.uid]);
      
      allow update: if isMember() && (
        // Action: Update Basic Info
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'avatar'])) ||
        // Action: Manage Members
        (incoming().diff(existing()).affectedKeys().hasOnly(['memberIds']) && incoming().memberIds.size() <= 50)
      );

      match /members/{memberId} {
        allow read: if isMember();
        allow write: if false; // Controlled via Group doc logic or specific triggers
      }

      match /expenses/{expenseId} {
        allow read: if isMember();
        allow create: if isMember() && isValidExpense(incoming()) && incoming().paidBy == request.auth.uid;
        allow update: if isMember() && isValidExpense(incoming()) && (
          incoming().paidBy == existing().paidBy && // paidBy cannot be changed easily
          incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'splits', 'category'])
        );
        allow delete: if isMember() && (existing().paidBy == request.auth.uid);
      }
    }
  }
}
